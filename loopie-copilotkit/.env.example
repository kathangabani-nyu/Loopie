AGENT_URL=http://localhost:8123
# If 8123 is in use, set AGENT_PORT=8124 and AGENT_URL=http://localhost:8124
# AGENT_PORT=8124
OPENAI_API_KEY=

# --- Loopie (mock-first; live only for cache-priming + recorded demo) ---
LOOPIE_LLM_MODE=mock
# Weave tracing/evals in mock mode when WANDB creds are present (hosted judging path)
LOOPIE_WEAVE_ENABLED=
# Opt-in live differential tests: LOOPIE_RUN_LIVE_TESTS=1 uv run pytest tests/test_live.py
LOOPIE_RUN_LIVE_TESTS=
LOOPIE_LIVE_CONFIRMED=
LOOPIE_REQUIRE_LIVE_LLM_CONFIRMATION=true
LOOPIE_LLM_SEED=42
LOOPIE_MAX_LLM_CALLS_PER_RUN=8
LOOPIE_MAX_LLM_CALLS_PER_EVAL=40
LOOPIE_MAX_AGENT_TRANSITIONS=6
LOOPIE_MAX_EVAL_CASES_PER_DEV_RUN=6
LOOPIE_MAX_ESTIMATED_COST_USD=0.25
LOOPIE_ENABLE_REPLAY_CACHE=true
LOOPIE_API_BASE=http://localhost:8001
# Hosted demo (Render): set LOOPIE_HOSTED=1 and durable REDIS_URL + POSTGRES_URL
LOOPIE_HOSTED=
LOOPIE_PERSISTENCE_MODE=auto
LOOPIE_FULL_AGENTIC=false
# Cursor bonus provider — disabled unless smoke marker + LOOPIE_PROVIDER_CURSOR_ENABLED=true
LOOPIE_PROVIDER_CURSOR_ENABLED=false

# Redis DB 1 + loopie: prefix (separate from CopilotKit Intelligence stack)
REDIS_URL=redis://localhost:6379/1

# Postgres loopie schema (reuse intelligence_app container)
POSTGRES_URL=postgresql://intelligence:intelligence@localhost:5432/intelligence_app

# Weave / W&B (can also live in repo root .env)
WANDB_API_KEY=
WANDB_ENTITY=
WEAVE_PROJECT=loopie

# --- CopilotKit Intelligence (optional; set COPILOTKIT_LICENSE_TOKEN to enable Threads) ---
# COPILOTKIT_LICENSE_TOKEN=
# INTELLIGENCE_API_URL=http://localhost:4201
# INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401
# INTELLIGENCE_API_KEY=

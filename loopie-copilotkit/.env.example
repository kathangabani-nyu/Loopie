AUTH_SECRET=replace-with-at-least-32-random-bytes
LOOPIE_ADMIN_PASSWORD=replace-with-a-strong-owner-password
LOOPIE_API_TOKEN=replace-with-a-random-service-token
LOOPIE_UI_ORIGIN=http://localhost:3000
LOOPIE_ENABLE_ADMIN_RESET=true
LOOPIE_JUDGE_ENABLED=false
LOOPIE_JUDGE_MODEL=gpt-5.6-terra
LOOPIE_JUDGE_MIN_CALIBRATION=0.8
OPENAI_API_KEY=
LOOPIE_OPENAI_MODEL=gpt-5.6-luna

# Local development defaults to deterministic test mode. Hosted runs use live.
LOOPIE_LLM_MODE=test
LOOPIE_WEAVE_ENABLED=false
# Opt-in live differential tests: LOOPIE_RUN_LIVE_TESTS=1 uv run pytest tests/test_live.py
LOOPIE_RUN_LIVE_TESTS=
LOOPIE_LIVE_CONFIRMED=
LOOPIE_REQUIRE_LIVE_LLM_CONFIRMATION=true
LOOPIE_LLM_SEED=42
LOOPIE_MAX_LLM_CALLS_PER_RUN=8
LOOPIE_MAX_LLM_CALLS_PER_EVAL=40
LOOPIE_MAX_AGENT_TRANSITIONS=6
LOOPIE_MAX_EVAL_CASES_PER_DEV_RUN=6
LOOPIE_MAX_ESTIMATED_COST_USD=0.25
LOOPIE_ENABLE_REPLAY_CACHE=true
LOOPIE_API_BASE=http://localhost:8001
# Hosted product: set LOOPIE_HOSTED=1 and durable Redis/Postgres URLs.
LOOPIE_HOSTED=
LOOPIE_PERSISTENCE_MODE=auto
LOOPIE_FULL_AGENTIC=true
# Cursor bonus provider — disabled unless smoke marker + LOOPIE_PROVIDER_CURSOR_ENABLED=true
LOOPIE_PROVIDER_CURSOR_ENABLED=false

# Redis DB 1 with project-scoped loopie:{project_id}: keys.
REDIS_URL=redis://localhost:6379/1
# Hosted mode requires REDIS_URL to start with rediss:// (TLS) unless you
# explicitly opt out. Free-tier Redis Cloud does not support TLS at all —
# either use a provider with free TLS (e.g. Upstash) or set this to "1" as a
# deliberate, informed choice to run hosted Redis traffic unencrypted.
LOOPIE_ALLOW_INSECURE_REDIS=false

# Postgres loopie schema (reuse intelligence_app container)
POSTGRES_URL=postgresql://intelligence:intelligence@localhost:5432/intelligence_app

# Weave / W&B. Set LOOPIE_WEAVE_ENABLED=true in hosted environments.
WANDB_API_KEY=
# WANDB_ENTITY must be your W&B *default entity* (often "<username>-..."), NOT your display
# username — the wrong value 404s the dashboard. Find it: wandb.ai → click your avatar → it's
# the team/username slug in the URL, or run the GraphQL `viewer { entity }` query.
WANDB_ENTITY=
WEAVE_PROJECT=loopie

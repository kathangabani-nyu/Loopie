{
  "name": "copilotkit-langgraph-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:loopie\" --names ui,api --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:ui": "next dev --webpack",
    "dev:agent": "npm run dev:loopie",
    "dev:loopie": "cd agent && uv run python loopie_dev.py",
    "build": "next build",
    "start": "next start",
    "install:agent": "./scripts/setup-agent.sh || scripts\\setup-agent.bat",
    "postinstall": "npm run install:agent",
    "dev:infra": "docker compose up -d --wait postgres redis",
    "dev:stack": "npm run dev:infra && npm run dev"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@copilotkit/react-core": "1.59.5",
    "@copilotkit/runtime": "1.59.5",
    "hono": "^4.12.29",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  }
}

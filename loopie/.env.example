# Loopie environment template
# Copy to .env and fill in secrets:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows)
#
# Never commit .env — it is gitignored.

# -----------------------------------------------------------------------------
# Weave / Weights & Biases (tracing, evals, before/after proof)
# Get API key: https://wandb.ai/authorize
# After `wandb login`, you can also copy the key from your W&B account settings.
# -----------------------------------------------------------------------------
WANDB_API_KEY=
WANDB_ENTITY=
WEAVE_PROJECT=loopie

# -----------------------------------------------------------------------------
# OpenAI (agent reasoning, optional failure summaries)
# Shape: sk-proj-... or sk-...
# Get key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Loopie live tests (opt-in; default pytest stays mock / $0)
# LOOPIE_RUN_LIVE_TESTS=1 LOOPIE_LLM_MODE=live LOOPIE_LIVE_CONFIRMED=1 uv run pytest tests/test_live.py
# -----------------------------------------------------------------------------
LOOPIE_LLM_MODE=mock
LOOPIE_WEAVE_ENABLED=
LOOPIE_RUN_LIVE_TESTS=
LOOPIE_LIVE_CONFIRMED=

# -----------------------------------------------------------------------------
# Redis (correction substrate — memory, routing, streams)
# Local default (Docker): docker run -p 6379:6379 redis
# Cloud shape: redis://default:<password>@<host>:<port>
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Loopie API (backend + MCP)
# Used by loopie-local MCP and Claude Code (.mcp.json).
# -----------------------------------------------------------------------------
LOOPIE_API_BASE=http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend (Next.js — exposed to browser, must be NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:8000

# -----------------------------------------------------------------------------
# GitHub MCP (Cursor .cursor/mcp.json — optional, for PRs/issues in editor)
# Shape: ghp_... or github_pat_...
# Create token: https://github.com/settings/tokens
# Scopes: repo (read/write as needed)
# -----------------------------------------------------------------------------
GITHUB_PERSONAL_ACCESS_TOKEN=
